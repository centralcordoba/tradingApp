# Base de datos — vacío = SQLite local, con URL = PostgreSQL (Supabase)
# Formato Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# OpenRouter (opcional — sin key el motor usa solo heurística)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_REFERER=http://localhost
USE_AI=0
